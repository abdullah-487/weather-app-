pipeline {
 agent any

 stages {

  stage('Clone Repo') {
   steps {
    git 'https://github.com/abdullah-487/weather-cicd-app.git'
   }
  }

  stage('Install Dependencies') {
   steps {
    sh 'pip3 install -r requirements.txt'
   }
  }

  stage('Run App') {
   steps {
    sh 'nohup python3 app.py &'
   }
  }

 }

}
